include README.md
include VERSIONS.md
include PUBLISHING.md
include .gitlab-ci.yml
include .github/workflows/*.yml
include pyproject.toml
include setup.py
include .vscode/settings.json
recursive-include src/dsgovbr/static *
recursive-include src/dsgovbr/templates *
recursive-include src/dsgovbr/templatetags *
