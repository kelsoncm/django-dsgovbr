recursive-include src/dsgovbr/admin.py
recursive-include src/dsgovbr/apps.py
recursive-include src/dsgovbr/__init__.py
recursive-include src/dsgovbr/migrations *
recursive-include src/dsgovbr/* *
# NÃO incluir a pasta examples no sdist
prune examples
prune README.md
prune VERSIONS.md
prune PUBLISHING.md
prune .gitlab-ci.yml
prune .github/workflows/*.yml
prune .vscode/settings.json